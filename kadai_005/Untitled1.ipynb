      "source": [
        "# 台形の面積の計算\n",
        "jyouhen = 10\n",
        "kahen = 20\n",
        "takasa = 5\n",
        "\n",
        "# 公式：台形の面積 =（上辺＋下辺）× 高さ ÷ 2\n",
        "menseki = (jyouhen + kahen) * takasa / 2\n",
        "\n",
        "# 面積の表示\n",
        "print(f\"{menseki}cm²\")"
      ]
    }
  ]
}